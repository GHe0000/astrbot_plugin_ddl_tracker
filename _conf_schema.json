{
  "enabled": {
    "description": "Enable this demo plugin.",
    "type": "bool",
    "default": true
  },
  "timezone": {
    "description": "Timezone name used by the plugin.",
    "type": "string",
    "default": "Asia/Shanghai"
  },
  "remind_before_minutes": {
    "description": "Example integer config item.",
    "type": "int",
    "default": 60
  },
  "admin_ids": {
    "description": "Example list config item.",
    "type": "list",
    "default": []
  },
  "debug": {
    "description": "Nested object config example.",
    "type": "object",
    "items": {
      "log_config_on_start": {
        "description": "Log the parsed config during startup.",
        "type": "bool",
        "default": true
      },
      "note": {
        "description": "Optional note for debugging.",
        "type": "string",
        "default": ""
      }
    }
  }
}
